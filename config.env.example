# BinanceSentinel · 链哨 环境配置
# 复制此文件为 .env 并填入你的API密钥

# ============================================
# BSCScan API Key (必须 / Required)
# 免费注册: https://bscscan.com/register
# 免费账户限额: 5次/秒, 100,000次/天
# ============================================
BSCSCAN_API_KEY=your_bscscan_api_key_here

# ============================================
# Telegram Bot 配置 (可选 / Optional)
# 用于接收价格预警和定时简报推送
#
# 获取 BOT_TOKEN:
#   1. 在 Telegram 搜索 @BotFather
#   2. 发送 /newbot 创建新机器人
#   3. 复制得到的 Token
#
# 获取 CHAT_ID:
#   1. 在 Telegram 搜索 @userinfobot
#   2. 发送 /start 获取你的 Chat ID
# ============================================
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ============================================
# Binance API (可选 / Optional)
# 公开市场数据无需API Key
# 仅在需要个人账户数据时才配置
# 警告: 请勿给予交易权限！只需读取权限
# ============================================
# BINANCE_API_KEY=your_binance_api_key_read_only
# BINANCE_API_SECRET=your_binance_api_secret_read_only
